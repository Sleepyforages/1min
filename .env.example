# ── Polymarket CLOB credentials ────────────────────────────────────────────────
# PRIVATE_KEY: the private key used for signing orders.
#   - If you use a proxy/operator wallet (Relayer signer), put that key here
#     and set POLYMARKET_FUNDER_ADDRESS to your main MetaMask wallet address.
#   - If you use your main MetaMask wallet directly, put that key here
#     and leave POLYMARKET_FUNDER_ADDRESS unset.
POLYMARKET_PRIVATE_KEY=0xyour_private_key_here

# FUNDER_ADDRESS: your main MetaMask wallet (holds USDC).
# Only needed if PRIVATE_KEY is for a proxy wallet, not the main wallet.
# POLYMARKET_FUNDER_ADDRESS=0xyour_main_wallet_address_here

# CLOB API credentials — NOT the Builder API key.
# Generate by running: docker exec polymarket-hedge-bot python -m scripts.generate_clob_creds
POLYMARKET_API_KEY=your_clob_api_key_here
POLYMARKET_API_SECRET=your_clob_api_secret_here
POLYMARKET_API_PASSPHRASE=your_clob_api_passphrase_here

# Price feed — Massive.com (formerly Polygon.io, same API key works)
# Get key at: https://massive.com
POLYGON_API_KEY=your_massive_com_key_here
# CCXT (Binance/Bybit) is used as fallback if key not set

# Optional: Telegram alerts
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
